---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Fancy Text Generator вҖ” Cool Unicode Fonts Online | QuickTextConverter"
  description="Free fancy text generator. Convert your text into cool Unicode fonts вҖ” cursive, bold, italic, gothic, double-struck, circled and more. Perfect for Instagram, Twitter and Discord."
  canonical="https://quicktextconverter.com/fancy-text-generator"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Fancy Text Generator</h1>
  <p class="text-gray-500 mb-6">Type your text and instantly get cool Unicode font styles to copy and paste anywhere.</p>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <input
      id="input"
      type="text"
      placeholder="Type your text here..."
      class="w-full rounded-lg border border-gray-300 p-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 text-lg"
    />
    <p class="text-xs text-gray-400 mt-1 mb-5">Click any style below to copy it instantly</p>

    <div id="results" class="space-y-2"></div>
  </div>

  <div class="mt-8 prose prose-sm max-w-none text-gray-600">
    <h2 class="text-lg font-semibold text-gray-800">Where can I use fancy text?</h2>
    <ul class="space-y-1 list-disc pl-5">
      <li><strong>Instagram bio</strong> вҖ” stand out with a unique font style</li>
      <li><strong>Twitter / X username or bio</strong> вҖ” make your profile memorable</li>
      <li><strong>Discord username or messages</strong> вҖ” add personality to your chats</li>
      <li><strong>WhatsApp and Telegram</strong> вҖ” send messages in cool styles</li>
      <li><strong>YouTube channel name or description</strong></li>
    </ul>
    <h2 class="text-lg font-semibold text-gray-800 mt-4">How does it work?</h2>
    <p>These aren't custom fonts вҖ” they are standard Unicode characters that look like different letter styles. Because they are real characters, they can be copied and pasted anywhere text is accepted, including social media bios, usernames, and messages.</p>
  </div>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I make fancy text for Instagram?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Type your text in the box above, then click any fancy style to copy it. Open Instagram, go to Edit Profile, paste the copied text into your bio or name field, and save. The fancy text will appear because it uses special Unicode characters."
      }
    },
    {
      "@type": "Question",
      "name": "Will fancy text work on all platforms?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fancy text works on most platforms including Instagram, Twitter/X, Facebook, Discord, WhatsApp, Telegram, TikTok and YouTube. Some platforms may strip certain Unicode characters вҖ” if one style doesn't work, try another."
      }
    },
    {
      "@type": "Question",
      "name": "Is fancy text a real font?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No вҖ” fancy text uses special Unicode characters that look like styled letters. They are not actual fonts. This is why they can be copied and pasted anywhere, including in text fields that don't allow font changes."
      }
    }
  ]
}
</script>

<script is:inline>
  const upper = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'
  const lower = 'abcdefghijklmnopqrstuvwxyz'

  const styles = [
    {
      name: 'рқҗҒрқҗЁрқҗҘрқҗқ',
      u: 'рқҗҖрқҗҒрқҗӮрқҗғрқҗ„рқҗ…рқҗҶрқҗҮрқҗҲрқҗүрқҗҠрқҗӢрқҗҢрқҗҚрқҗҺрқҗҸрқҗҗрқҗ‘рқҗ’рқҗ“рқҗ”рқҗ•рқҗ–рқҗ—рқҗҳрқҗҷ',
      l: 'рқҗҡрқҗӣрқҗңрқҗқрқҗһрқҗҹрқҗ рқҗЎрқҗўрқҗЈрқҗӨрқҗҘрқҗҰрқҗ§рқҗЁрқҗ©рқҗӘрқҗ«рқҗ¬рқҗӯрқҗ®рқҗҜрқҗ°рқҗұрқҗІрқҗі',
    },
    {
      name: 'рқҳҗрқҳөрқҳўрқҳӯрқҳӘрқҳӨ',
      u: 'рқҳҲрқҳүрқҳҠрқҳӢрқҳҢрқҳҚрқҳҺрқҳҸрқҳҗрқҳ‘рқҳ’рқҳ“рқҳ”рқҳ•рқҳ–рқҳ—рқҳҳрқҳҷрқҳҡрқҳӣрқҳңрқҳқрқҳһрқҳҹрқҳ рқҳЎ',
      l: 'рқҳўрқҳЈрқҳӨрқҳҘрқҳҰрқҳ§рқҳЁрқҳ©рқҳӘрқҳ«рқҳ¬рқҳӯрқҳ®рқҳҜрқҳ°рқҳұрқҳІрқҳірқҳҙрқҳөрқҳ¶рқҳ·рқҳёрқҳ№рқҳәрқҳ»',
    },
    {
      name: 'рқҷұрқҡҳрқҡ•рқҡҚ рқҷёрқҡқрқҡҠрқҡ•рқҡ’рқҡҢ',
      u: 'рқ‘Ёрқ‘©рқ‘Әрқ‘«рқ‘¬рқ‘ӯрқ‘®рқ‘Ҝрқ‘°рқ‘ұрқ‘Ірқ‘ірқ‘ҙрқ‘өрқ‘¶рқ‘·рқ‘ёрқ‘№рқ‘әрқ‘»рқ‘јрқ‘Ҫрқ‘ҫрқ‘ҝрқ’Җрқ’Ғ',
      l: 'рқ’Ӯрқ’ғрқ’„рқ’…рқ’Ҷрқ’Үрқ’Ҳрқ’үрқ’Ҡрқ’Ӣрқ’Ңрқ’Қрқ’Һрқ’Ҹрқ’җрқ’‘рқ’’рқ’“рқ’”рқ’•рқ’–рқ’—рқ’ҳрқ’ҷрқ’ҡрқ’ӣ',
    },
    {
      name: 'рқ“’рқ“ҫрқ“»рқ“јрқ“Ірқ“ҝрқ“®',
      u: 'рқ“җрқ“‘рқ“’рқ““рқ“”рқ“•рқ“–рқ“—рқ“ҳрқ“ҷрқ“ҡрқ“ӣрқ“ңрқ“қрқ“һрқ“ҹрқ“ рқ“Ўрқ“ўрқ“Јрқ“Өрқ“Ҙрқ“Ұрқ“§рқ“Ёрқ“©',
      l: 'рқ“Әрқ“«рқ“¬рқ“ӯрқ“®рқ“Ҝрқ“°рқ“ұрқ“Ірқ“ірқ“ҙрқ“өрқ“¶рқ“·рқ“ёрқ“№рқ“әрқ“»рқ“јрқ“Ҫрқ“ҫрқ“ҝрқ”Җрқ”Ғрқ”Ӯрқ”ғ',
    },
    {
      name: 'рқ”Ҡрқ”¬рқ”ұрқ”Ҙрқ”Ұрқ” ',
      u: 'рқ”„рқ”…в„ӯрқ”Үрқ”Ҳрқ”үрқ”Ҡв„Ңв„‘рқ”Қрқ”Һрқ”Ҹрқ”җрқ”‘рқ”’рқ”“рқ””в„ңрқ”–рқ”—рқ”ҳрқ”ҷрқ”ҡрқ”ӣрқ”ңв„Ё',
      l: 'рқ”һрқ”ҹрқ” рқ”Ўрқ”ўрқ”Јрқ”Өрқ”Ҙрқ”Ұрқ”§рқ”Ёрқ”©рқ”Әрқ”«рқ”¬рқ”ӯрқ”®рқ”Ҝрқ”°рқ”ұрқ”Ірқ”ірқ”ҙрқ”өрқ”¶рқ”·',
    },
    {
      name: 'рқ•Ҝрқ–”рқ–ҡрқ–Үрқ–‘рқ–Ҡ рқ•ҫрқ–ҷрқ–—рқ–ҡрқ–Ҳрқ–җ',
      u: 'рқ”ёрқ”№в„Ӯрқ”»рқ”јрқ”Ҫрқ”ҫв„Қрқ•Җрқ•Ғрқ•Ӯрқ•ғрқ•„в„•рқ•Ҷв„ҷв„ҡв„қрқ•Ҡрқ•Ӣрқ•Ңрқ•Қрқ•Һрқ•Ҹрқ•җв„Ө',
      l: 'рқ•’рқ•“рқ•”рқ••рқ•–рқ•—рқ•ҳрқ•ҷрқ•ҡрқ•ӣрқ•ңрқ•қрқ•һрқ•ҹрқ• рқ•Ўрқ•ўрқ•Јрқ•Өрқ•Ҙрқ•Ұрқ•§рқ•Ёрқ•©рқ•Әрқ•«',
    },
    {
      name: 'в’ёв“ҳв“Ўв“’в“ӣв“”в““',
      u: 'в’¶в’·в’ёв’№в’әв’»в’јв’Ҫв’ҫв’ҝв“Җв“Ғв“Ӯв“ғв“„в“…в“Ҷв“Үв“Ҳв“үв“Ҡв“Ӣв“Ңв“Қв“Һв“Ҹ',
      l: 'в“җв“‘в“’в““в“”в“•в“–в“—в“ҳв“ҷв“ҡв“ӣв“ңв“қв“һв“ҹв“ в“Ўв“ўв“Јв“Өв“Ҙв“Ұв“§в“Ёв“©',
    },
    {
      name: 'пјҰпҪ•пҪҢпҪҢпҪ—пҪүпҪ„пҪ”пҪҲ',
      u: 'пјЎпјўпјЈпјӨпјҘпјҰпј§пјЁпј©пјӘпј«пј¬пјӯпј®пјҜпј°пјұпјІпјіпјҙпјөпј¶пј·пјёпј№пјә',
      l: 'пҪҒпҪӮпҪғпҪ„пҪ…пҪҶпҪҮпҪҲпҪүпҪҠпҪӢпҪҢпҪҚпҪҺпҪҸпҪҗпҪ‘пҪ’пҪ“пҪ”пҪ•пҪ–пҪ—пҪҳпҪҷпҪҡ',
    },
    {
      name: 'бҙӣЙӘЙҙКҸ бҙ„бҙҖбҙҳкңұ',
      u: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      l: 'бҙҖКҷбҙ„бҙ…бҙҮкң°ЙўКңЙӘбҙҠбҙӢКҹбҙҚЙҙбҙҸбҙҳQКҖкңұбҙӣбҙңбҙ бҙЎxКҸбҙў',
    },
    {
      name: 'SМ¶tМ¶rМ¶iМ¶kМ¶eМ¶tМ¶hМ¶rМ¶oМ¶uМ¶gМ¶hМ¶',
      strike: true,
    },
    {
      name: 'UНҹnНҹdНҹeНҹrНҹlНҹiНҹnНҹeНҹ',
      underline: true,
    },
  ]

  function convert(text, style) {
    if (style.strike) return text.split('').map(c => c + 'М¶').join('')
    if (style.underline) return text.split('').map(c => c + 'МІ').join('')
    return text.split('').map(c => {
      const ui = upper.indexOf(c)
      const li = lower.indexOf(c)
      if (ui !== -1) return [...style.u][ui]
      if (li !== -1) return [...style.l][li]
      return c
    }).join('')
  }

  function render() {
    const text = document.getElementById('input').value || 'Fancy Text'
    const container = document.getElementById('results')
    container.innerHTML = styles.map((style, i) => {
      const converted = convert(text, style)
      return `
        <div class="flex items-center justify-between gap-3 p-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-all group cursor-pointer" data-index="${i}">
          <div>
            <span class="text-xs text-gray-400 block mb-0.5">${style.name}</span>
            <span class="text-base text-gray-800 select-all" id="result-${i}">${converted}</span>
          </div>
          <button class="shrink-0 text-xs bg-white border border-gray-200 group-hover:border-blue-400 group-hover:text-blue-600 text-gray-500 px-3 py-1.5 rounded-md transition-colors copy-style-btn" data-index="${i}">
            Copy
          </button>
        </div>
      `
    }).join('')

    container.querySelectorAll('.copy-style-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation()
        const idx = btn.dataset.index
        const text = document.getElementById(`result-${idx}`).textContent
        navigator.clipboard.writeText(text)
        btn.textContent = 'Copied!'
        setTimeout(() => btn.textContent = 'Copy', 1500)
      })
    })
  }

  document.getElementById('input').addEventListener('input', render)
  render()
</script>
