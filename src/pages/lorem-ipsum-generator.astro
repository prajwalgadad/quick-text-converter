---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Lorem Ipsum Generator — Free Placeholder Text Online | QuickTextConverter"
  description="Free Lorem Ipsum generator. Generate placeholder text by paragraphs, sentences or words. Copy instantly for design mockups, websites and prototypes."
  canonical="https://quicktextconverter.com/lorem-ipsum-generator"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Lorem Ipsum Generator</h1>
  <p class="text-gray-500 mb-6">Generate placeholder text instantly for your designs and mockups.</p>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <div class="flex flex-wrap gap-4 mb-5 items-end">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Generate</label>
        <input
          id="count"
          type="number"
          min="1"
          max="100"
          value="3"
          class="w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
        <select id="type" class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
          <option value="paragraphs">Paragraphs</option>
          <option value="sentences">Sentences</option>
          <option value="words">Words</option>
        </select>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" id="start-lorem" checked class="rounded" />
        <label for="start-lorem" class="text-sm text-gray-700">Start with "Lorem ipsum..."</label>
      </div>
      <button
        id="generate-btn"
        class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
      >
        Generate
      </button>
    </div>

    <div class="relative">
      <textarea
        id="output"
        rows="10"
        readonly
        class="w-full resize-y rounded-lg border border-gray-300 bg-gray-50 p-3 text-sm font-mono focus:outline-none"
      ></textarea>
      <button
        id="copy-btn"
        class="absolute top-2 right-2 text-xs bg-blue-600 text-white px-3 py-1.5 rounded-md hover:bg-blue-700 transition-colors"
      >
        Copy
      </button>
    </div>
  </div>

  <div class="mt-8 prose prose-sm max-w-none text-gray-600">
    <h2 class="text-lg font-semibold text-gray-800">What is Lorem Ipsum?</h2>
    <p>Lorem Ipsum is placeholder text used by designers, developers and printers since the 1500s. It originates from sections 1.10.32 and 1.10.33 of "de Finibus Bonorum et Malorum" by Cicero, written in 45 BC.</p>
    <p>It remains the standard placeholder text today because it has a natural distribution of letters and words, making layouts look realistic without distracting readable content.</p>
  </div>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Lorem Ipsum?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lorem Ipsum is placeholder text used by designers, developers, and publishers since the 1500s. It resembles readable text so layouts look realistic without distracting the viewer with meaningful content."
      }
    },
    {
      "@type": "Question",
      "name": "Where does Lorem Ipsum come from?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lorem Ipsum originates from sections 1.10.32 and 1.10.33 of 'de Finibus Bonorum et Malorum' (On the Ends of Good and Evil) by the Roman philosopher Cicero, written in 45 BC."
      }
    },
    {
      "@type": "Question",
      "name": "Why do designers use Lorem Ipsum?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Designers use Lorem Ipsum because it has a natural distribution of letters and word lengths, making layouts look realistic. Using real content can distract reviewers from evaluating the design itself."
      }
    },
    {
      "@type": "Question",
      "name": "How do I generate Lorem Ipsum text?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the Lorem Ipsum generator above. Choose how many paragraphs, sentences, or words you need, optionally start with the classic 'Lorem ipsum dolor sit amet...' opening, then click Generate and copy the result."
      }
    }
  ]
}
</script>

<script is:inline>
  const words = [
    'lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit','sed','do',
    'eiusmod','tempor','incididunt','ut','labore','et','dolore','magna','aliqua','enim',
    'ad','minim','veniam','quis','nostrud','exercitation','ullamco','laboris','nisi',
    'aliquip','ex','ea','commodo','consequat','duis','aute','irure','in','reprehenderit',
    'voluptate','velit','esse','cillum','fugiat','nulla','pariatur','excepteur','sint',
    'occaecat','cupidatat','non','proident','sunt','culpa','qui','officia','deserunt',
    'mollit','anim','id','est','laborum','perspiciatis','unde','omnis','iste','natus',
    'error','accusantium','doloremque','laudantium','totam','rem','aperiam','eaque','ipsa',
    'quae','ab','illo','inventore','veritatis','quasi','architecto','beatae','vitae',
    'dicta','explicabo','nemo','ipsam','quia','voluptas','aspernatur','odit','aut','fugit',
  ]

  const lorem = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.'

  function randomWord() {
    return words[Math.floor(Math.random() * words.length)]
  }

  function randomSentence() {
    const len = 8 + Math.floor(Math.random() * 12)
    const w = Array.from({ length: len }, randomWord)
    w[0] = w[0].charAt(0).toUpperCase() + w[0].slice(1)
    return w.join(' ') + '.'
  }

  function randomParagraph() {
    const count = 4 + Math.floor(Math.random() * 4)
    return Array.from({ length: count }, randomSentence).join(' ')
  }

  function generate() {
    const count = Math.max(1, Math.min(100, parseInt(document.getElementById('count').value) || 3))
    const type = document.getElementById('type').value
    const startLorem = document.getElementById('start-lorem').checked
    let result = ''

    if (type === 'paragraphs') {
      const paras = Array.from({ length: count }, (_, i) =>
        i === 0 && startLorem ? lorem + ' ' + randomParagraph() : randomParagraph()
      )
      result = paras.join('\n\n')
    } else if (type === 'sentences') {
      const sents = Array.from({ length: count }, (_, i) =>
        i === 0 && startLorem ? lorem : randomSentence()
      )
      result = sents.join(' ')
    } else {
      const ws = Array.from({ length: count }, (_, i) =>
        i === 0 && startLorem ? 'Lorem' : randomWord()
      )
      result = ws.join(' ')
    }

    document.getElementById('output').value = result
  }

  document.getElementById('generate-btn').addEventListener('click', generate)

  document.getElementById('copy-btn').addEventListener('click', () => {
    const output = document.getElementById('output')
    if (!output.value) return
    navigator.clipboard.writeText(output.value)
    const btn = document.getElementById('copy-btn')
    btn.textContent = 'Copied!'
    setTimeout(() => btn.textContent = 'Copy', 1500)
  })

  generate()
</script>
