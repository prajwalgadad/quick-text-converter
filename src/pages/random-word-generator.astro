---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Random Word Generator — Generate Random Words Free | QuickTextConverter"
  description="Free random word generator. Generate random nouns, verbs, adjectives or mixed words instantly. Great for writing prompts, games, brainstorming and creative projects."
  canonical="https://quicktextconverter.com/random-word-generator"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Random Word Generator</h1>
  <p class="text-gray-500 mb-6">Generate random words for writing prompts, brainstorming, word games and more.</p>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <div class="flex flex-wrap gap-4 mb-5 items-end">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Number of words</label>
        <input
          id="count"
          type="number"
          min="1"
          max="100"
          value="10"
          class="w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Word type</label>
        <select id="type" class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
          <option value="mixed">Mixed</option>
          <option value="nouns">Nouns</option>
          <option value="verbs">Verbs</option>
          <option value="adjectives">Adjectives</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Display as</label>
        <select id="display" class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
          <option value="list">List</option>
          <option value="inline">Inline (comma separated)</option>
        </select>
      </div>
      <button
        id="generate-btn"
        class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
      >
        Generate
      </button>
    </div>

    <div id="output" class="min-h-32 rounded-lg border border-gray-300 bg-gray-50 p-4"></div>

    <div class="flex justify-between mt-3">
      <span id="word-count-label" class="text-sm text-gray-500"></span>
      <button
        id="copy-btn"
        class="text-xs bg-blue-600 text-white px-3 py-1.5 rounded-md hover:bg-blue-700 transition-colors"
      >
        Copy All
      </button>
    </div>
  </div>

  <div class="mt-8 prose prose-sm max-w-none text-gray-600">
    <h2 class="text-lg font-semibold text-gray-800">Uses for random words</h2>
    <ul class="space-y-1 list-disc pl-5">
      <li><strong>Writing prompts</strong> — pick 3 random words and write a short story using all of them</li>
      <li><strong>Word games</strong> — Pictionary, charades, word association</li>
      <li><strong>Brainstorming</strong> — random words spark unexpected creative connections</li>
      <li><strong>Password inspiration</strong> — combine 3 random words for a memorable passphrase</li>
      <li><strong>Naming projects</strong> — random word combinations make memorable brand names</li>
    </ul>
  </div>
</Layout>

<script is:inline>
  const wordLists = {
    nouns: [
      'apple','bridge','candle','dragon','eagle','forest','garden','harbour','island','jungle',
      'kingdom','lantern','marble','needle','ocean','palace','quartz','river','shadow','tunnel',
      'umbrella','village','window','xylophone','yellow','zebra','anchor','barrel','castle','desert',
      'envelope','feather','glacier','hammer','invention','journal','kettle','lighthouse','mountain',
      'notebook','orange','pebble','rocket','storm','thunder','unicorn','vessel','whisper','crystal',
    ],
    verbs: [
      'build','climb','dance','explore','fly','gather','harvest','illuminate','journey','kindle',
      'launch','maintain','navigate','observe','paint','question','rescue','sail','transform','unlock',
      'venture','wander','accelerate','balance','capture','deliver','embrace','filter','generate',
      'handle','imagine','juggle','leap','measure','nurture','overcome','protect','radiate','stride',
    ],
    adjectives: [
      'ancient','brave','calm','daring','elegant','fierce','gentle','hidden','icy','joyful',
      'keen','luminous','massive','noble','open','peaceful','quiet','rapid','silent','tall',
      'unique','vast','warm','exact','young','zealous','bold','crisp','deep','endless',
      'fragile','grand','hollow','intense','lively','mysterious','narrow','ordinary','playful','radiant',
    ],
  }

  let lastWords = []

  function generate() {
    const count = Math.max(1, Math.min(100, parseInt(document.getElementById('count').value) || 10))
    const type = document.getElementById('type').value
    const display = document.getElementById('display').value

    let pool = []
    if (type === 'mixed') pool = [...wordLists.nouns, ...wordLists.verbs, ...wordLists.adjectives]
    else pool = wordLists[type]

    lastWords = Array.from({ length: count }, () => pool[Math.floor(Math.random() * pool.length)])

    const output = document.getElementById('output')
    if (display === 'list') {
      output.innerHTML = lastWords.map(w =>
        `<span class="inline-block bg-white border border-gray-200 rounded-full px-3 py-1 text-sm m-1 text-gray-800 hover:border-blue-400 cursor-default">${w}</span>`
      ).join('')
    } else {
      output.innerHTML = `<p class="text-sm text-gray-800">${lastWords.join(', ')}</p>`
    }

    document.getElementById('word-count-label').textContent = count + ' words generated'
  }

  document.getElementById('generate-btn').addEventListener('click', generate)

  document.getElementById('copy-btn').addEventListener('click', () => {
    if (!lastWords.length) return
    navigator.clipboard.writeText(lastWords.join(', '))
    const btn = document.getElementById('copy-btn')
    btn.textContent = 'Copied!'
    setTimeout(() => btn.textContent = 'Copy All', 1500)
  })

  generate()
</script>
